        "jsCode": "// Get unfinished tasks from previous Code node\nconst open = $node[\"Code in JavaScript1\"].json.open || [];\n\n// If nothing to move\nif (open.length === 0) {\n  return [{\n    json: {\n      movedCount: 0,\n      updates: []\n    }\n  }];\n}\n\nfunction toDate(iso) { return iso ? new Date(iso) : null; }\nfunction addDays(d, days) { const x = new Date(d); x.setDate(x.getDate() + days); return x; }\nfunction setTime(base, h, m) { const d = new Date(base); d.setHours(h, m, 0, 0); return d; }\nfunction durMinutes(s, e) { return Math.max(15, Math.round((e - s) / 60000)); }\n\nconst now = new Date();\nconst tomorrow = addDays(now, 1);\ntomorrow.setHours(0, 0, 0, 0);\n\n// Build tomorrow schedule (same time)\nlet proposed = open.map(t => {\n  const s = toDate(t.start_time);\n  const e = toDate(t.end_time);\n\n  let start = s\n    ? setTime(tomorrow, s.getHours(), s.getMinutes())\n    : setTime(tomorrow, 9, 0);\n\n  let end = e\n    ? setTime(tomorrow, e.getHours(), e.getMinutes())\n    : new Date(start.getTime() + 60 * 60000);\n\n  if (end <= start) {\n    end = new Date(start.getTime() + 60 * 60000);\n  }\n\n  const priority = (t.priority || \"normal\").toLowerCase();\n  const score =\n    priority === \"high\" ? 3 :\n    priority === \"medium\" ? 2 :\n    1;\n\n  return {\n    id: t.id,\n    duration: durMinutes(start, end),\n    proposedStart: start,\n    score\n  };\n});\n\n// Sort by priority (high first)\nproposed.sort((a, b) =>\n  b.score - a.score || a.proposedStart - b.proposedStart\n);\n\n// Overlap resolver\nconst scheduled = [];\n\nfunction overlaps(aS, aE, bS, bE) {\n  return aS < bE && bS < aE;\n}\n\nfor (const t of proposed) {\n  let s = new Date(t.proposedStart);\n  let e = new Date(s.getTime() + t.duration * 60000);\n\n  let ok = false;\n\n  while (!ok) {\n    ok = true;\n\n    for (const x of scheduled) {\n      if (overlaps(s, e, x.start, x.end)) {\n        ok = false;\n        s = new Date(x.end); // push after conflicting task\n        e = new Date(s.getTime() + t.duration * 60000);\n        break;\n      }\n    }\n  }\n\n  scheduled.push({\n    id: t.id,\n    start: s,\n    end: e\n  });\n}\n\nreturn [{\n  json: {\n    movedCount: scheduled.length,\n    updates: scheduled.map(x => ({\n      id: x.id,\n      start_time: x.start.toISOString(),\n      end_time: x.end.toISOString()\n    }))\n  }\n}];"
